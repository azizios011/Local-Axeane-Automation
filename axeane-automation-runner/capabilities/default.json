{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Axeane Automation desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "core:event:default",
    "core:webview:default",
    "core:app:default",
    "core:path:default",
    "core:resources:default",

    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/python-backend",
          "sidecar": true,
          "args": [
            "--host", { "validator": "^127\\.0\\.0\\.1$" },
            "--port", { "validator": "^\\d{2,5}$" }
          ]
        }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "shell:allow-open"
  ]
}
